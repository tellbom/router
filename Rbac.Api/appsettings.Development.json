{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },

  "Jwt": {
    "Mode": "TrustedJwt",
    "Authority": "",
    "Audience": "rbac-api",
    "Issuer": "your-portal",
    "RequireHttpsMetadata": false,
    "UseridClaim": "userid",
    "FallbackUseridClaims": [ "sub", "employee_id", "uid" ]
  },

  "ConnectionStrings": {
    "Rbac": "Server=192.168.124.2;Port=13306;Database=rbac;User=root;Password=123456;CharSet=utf8mb4;",
    "Redis": "192.168.124.2:16379,abortConnect=false,connectTimeout=5000,syncTimeout=5000"
  },

  "Redis": {
    "KeyPrefix": "rbac:",
    "DefaultDatabase": 0
  },

  "FusionCache": {
    "DefaultEntryOptions": {
      "Duration": "00:01:00",
      "DistributedCacheDuration": "00:30:00",
      "IsFailSafeEnabled": true,
      "FailSafeMaxDuration": "02:00:00",
      "FailSafeThrottleDuration": "00:00:30",
      "FactorySoftTimeout": "00:00:01",
      "FactoryHardTimeout": "00:00:05"
    }
  },

  "Elasticsearch": {
    "Uri": "http://192.168.124.2:19200",
    "DefaultIndex": "rbac",
    "Username": "",
    "Password": "",
    "EnableDebugMode": true
  },

  "Casbin": {
    "ModelPath": "casbin/model.conf",
    "PolicyReloadIntervalSeconds": 30
  },

  "Worker": {
    "OutboxPollingIntervalSeconds": 5,
    "OutboxMaxRetryCount": 5,
    "WarmupOnStartup": true
  },

  "Project": {
    "DefaultSource": "Header",
    "HeaderName": "X-Project",
    "AllowedSources": [ "Header", "Route", "Query" ]
  },

  "Allowlist": {
    "Routes": [
      "/api/auth/login",
      "/health",
      "/healthz",
      "/swagger",
      "/swagger/{*path}",
      "/favicon.ico"
    ]
  },

  "ProjectAccessAllowlist": {
    "Routes": [
      "/api/admin/index"
    ]
  }
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },

  "Jwt": {
    "Authority": "https://your-sso-host",
    "Audience": "rbac-api",
    "Issuer": "your-portal",
    "RequireHttpsMetadata": false,
    "UseridClaim": "sub",
    "FallbackUseridClaims": [ "employee_id", "uid" ]
  },

  "Database": {
    "MySql": {
      "ConnectionString": "Server=127.0.0.1;Port=3306;Database=rbac_center;User=rbac_user;Password=change_me;CharSet=utf8mb4;",
      "CommandTimeout": 30,
      "EnableSensitiveDataLogging": true
    }
  },

  "Redis": {
    "ConnectionString": "127.0.0.1:6379,abortConnect=false,connectTimeout=5000,syncTimeout=5000",
    "KeyPrefix": "rbac:",
    "DefaultDatabase": 0
  },

  "FusionCache": {
    "DefaultEntryOptions": {
      "Duration": "00:01:00",
      "DistributedCacheDuration": "00:30:00",
      "IsFailSafeEnabled": true,
      "FailSafeMaxDuration": "02:00:00",
      "FailSafeThrottleDuration": "00:00:30",
      "FactorySoftTimeout": "00:00:01",
      "FactoryHardTimeout": "00:00:05"
    }
  },

  "Elasticsearch": {
    "Nodes": [ "http://127.0.0.1:9200" ],
    "DefaultIndex": "rbac",
    "Username": "",
    "Password": "",
    "EnableDebugMode": true
  },

  "Casbin": {
    "ModelPath": "casbin/model.conf",
    "PolicyReloadIntervalSeconds": 30
  },

  "Worker": {
    "OutboxPollingIntervalSeconds": 5,
    "OutboxMaxRetryCount": 5,
    "WarmupOnStartup": true
  },

  "Project": {
    "DefaultSource": "Header",
    "HeaderName": "X-Project",
    "AllowedSources": [ "Header", "Route", "Query" ]
  },

  "Allowlist": {
    "Routes": [
      "/api/auth/login",
      "/health",
      "/healthz",
      "/swagger",
      "/swagger/{*path}",
      "/favicon.ico"
    ]
  }
}
